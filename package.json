{
  "name": "@trancendos/prometheus-ai",
  "version": "1.0.0",
  "description": "Monitoring and alerting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "security:audit": "pnpm audit --audit-level=high",
    "security:n-1": "node scripts/check-n-minus-one.mjs",
    "security:org-audit": "node scripts/org-security-audit.mjs",
    "security:all": "pnpm run security:n-1 && pnpm run security:audit"
  },
  "author": "Trancendos",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22"
  }
}
